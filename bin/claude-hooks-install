#!/usr/bin/env node
/* eslint-disable */
/** Cross-platform bin shim for `claude-hooks-install` — see claude-hook for design notes (P0-2). */
import { spawnSync } from "node:child_process"
import * as fs from "node:fs"
import * as path from "node:path"

const TARGET = "../scripts/install.ts"
const PROGRAM = "claude-hooks-install"

const resolveSource = () => {
  const arg = process.argv[1] ?? ""
  try {
    return fs.realpathSync(arg)
  } catch {
    return arg
  }
}

const isExecutableFile = (p) => {
  try {
    return fs.statSync(p).isFile()
  } catch {
    return false
  }
}

const findBun = () => {
  const env = process.env
  const isWin = process.platform === "win32"
  const bunExe = isWin ? "bun.exe" : "bun"
  const candidates = [
    env.BUN,
    env.HOME ? path.join(env.HOME, ".bun", "bin", bunExe) : null,
    env.USERPROFILE
      ? path.join(env.USERPROFILE, ".bun", "bin", bunExe)
      : null,
    "/opt/homebrew/bin/bun",
    "/usr/local/bin/bun",
  ].filter(Boolean)
  for (const c of candidates) {
    if (isExecutableFile(c)) return c
  }
  const probe = spawnSync(isWin ? "where" : "which", ["bun"], {
    encoding: "utf8",
  })
  if (probe.status === 0) {
    const first = probe.stdout.trim().split(/\r?\n/)[0]
    if (first && isExecutableFile(first)) return first
  }
  return null
}

const source = resolveSource()
const here = path.dirname(source)
const bun = findBun()
if (!bun) {
  process.stderr.write(`${PROGRAM}: bun not found.\n`)
  process.stderr.write("  Set $BUN to an absolute path, or install bun:\n")
  process.stderr.write("    POSIX:   curl -fsSL https://bun.sh/install | bash\n")
  process.stderr.write(
    "    Windows: powershell -c \"irm bun.sh/install.ps1 | iex\"\n",
  )
  process.exit(1)
}
const target = path.join(here, TARGET)
const result = spawnSync(bun, ["run", target, ...process.argv.slice(2)], {
  stdio: "inherit",
})
process.exit(result.status ?? 1)
