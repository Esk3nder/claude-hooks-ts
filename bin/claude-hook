#!/usr/bin/env bash
# Robust bin shim for claude-hooks-ts. Two failure modes the naive
# `exec bun run "$(dirname "$0")/../src/dispatcher.ts" "$@"` shim has:
#
#   1. $(dirname "$0") does NOT resolve symlinks. When a package manager
#      (`bun add -g`, `npm i -g`, etc.) symlinks this shim onto PATH,
#      $0 is the symlink path, so the relative `../src/dispatcher.ts` resolves
#      against the wrong directory and fails with "Module not found".
#
#   2. Bare `bun` requires `bun` on PATH. Hook subprocesses spawned by
#      Claude Code run with a sanitized PATH that does not include
#      $HOME/.bun/bin, so `exec bun` fails with "bun: not found" and
#      every hook event errors out.
#
# The block below resolves the symlink portably (works on macOS bash 3.2
# without GNU `readlink -f`) and probes for bun in the common locations
# before falling back to PATH lookup.
set -e
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in /*) SOURCE="$TARGET" ;; *) SOURCE="$(dirname "$SOURCE")/$TARGET" ;; esac
done
HERE="$(cd "$(dirname "$SOURCE")" && pwd)"
BUN="${BUN:-}"
if [ -z "$BUN" ] || [ ! -x "$BUN" ]; then
  for c in "$HOME/.bun/bin/bun" "/opt/homebrew/bin/bun" "/usr/local/bin/bun" "$(command -v bun 2>/dev/null || true)"; do
    if [ -n "$c" ] && [ -x "$c" ]; then BUN="$c"; break; fi
  done
fi
if [ ! -x "$BUN" ]; then
  echo "claude-hook: bun not found." >&2
  echo "  Set \$BUN to an absolute path, or install bun:" >&2
  echo "    curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi
exec "$BUN" run "$HERE/../src/dispatcher.ts" "$@"
