#!/usr/bin/env node
/* eslint-disable */
/**
 * Cross-platform bin shim for `claude-hook`. P0-2 — replaces the prior
 * bash shim so Windows installs work without WSL/Git-Bash.
 *
 * Same two failure modes the bash version guarded against still apply:
 *   1. `process.argv[1]` is the symlink path when a package manager
 *      (`bun add -g`, `npm i -g`, ...) puts this on PATH. `fs.realpathSync`
 *      resolves the symlink so the relative `../src/dispatcher.ts`
 *      anchors to the package install root.
 *   2. Bare `bun` requires `bun` on PATH. Claude Code spawns hooks with
 *      a sanitized PATH that omits `$HOME/.bun/bin`. We probe
 *      `$BUN` -> `~/.bun/bin/bun(.exe)` -> `/opt/homebrew/bin/bun` ->
 *      `/usr/local/bin/bun` -> PATH lookup before giving up.
 *
 * Why Node not bash: bash isn't on Windows by default; cmd-shim generated
 * by npm/bun reads the shebang and invokes `node`, which IS reliably
 * available on Windows. The shim's job is purely to find bun and re-exec.
 */
import { spawnSync } from "node:child_process"
import * as fs from "node:fs"
import * as path from "node:path"

const TARGET = "../src/dispatcher.ts"
const PROGRAM = "claude-hook"

const resolveSource = () => {
  const arg = process.argv[1] ?? ""
  try {
    return fs.realpathSync(arg)
  } catch {
    return arg
  }
}

const isExecutableFile = (p) => {
  try {
    const st = fs.statSync(p)
    return st.isFile()
  } catch {
    return false
  }
}

const findBun = () => {
  const env = process.env
  const isWin = process.platform === "win32"
  const bunExe = isWin ? "bun.exe" : "bun"
  const candidates = [
    env.BUN,
    env.HOME ? path.join(env.HOME, ".bun", "bin", bunExe) : null,
    env.USERPROFILE
      ? path.join(env.USERPROFILE, ".bun", "bin", bunExe)
      : null,
    "/opt/homebrew/bin/bun",
    "/usr/local/bin/bun",
  ].filter(Boolean)
  for (const c of candidates) {
    if (isExecutableFile(c)) return c
  }
  const probe = spawnSync(isWin ? "where" : "which", ["bun"], {
    encoding: "utf8",
  })
  if (probe.status === 0) {
    const first = probe.stdout.trim().split(/\r?\n/)[0]
    if (first && isExecutableFile(first)) return first
  }
  return null
}

const source = resolveSource()
const here = path.dirname(source)
const bun = findBun()
if (!bun) {
  process.stderr.write(`${PROGRAM}: bun not found.\n`)
  process.stderr.write("  Set $BUN to an absolute path, or install bun:\n")
  process.stderr.write("    POSIX:   curl -fsSL https://bun.sh/install | bash\n")
  process.stderr.write(
    "    Windows: powershell -c \"irm bun.sh/install.ps1 | iex\"\n",
  )
  process.exit(1)
}
const target = path.join(here, TARGET)
const result = spawnSync(bun, ["run", target, ...process.argv.slice(2)], {
  stdio: "inherit",
})
process.exit(result.status ?? 1)
