    "install:apply": "bun run scripts/install.ts --apply"
  },
  "dependencies": {
    "effect": "^3.10.0",
    "@effect/platform": "^0.69.0",
    "@effect/platform-bun": "^0.49.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.6.0"
  }
