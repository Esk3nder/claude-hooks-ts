{
  "name": "claude-hooks-ts",
  "version": "0.0.0",
  "description": "Type-safe, Effect-based dispatcher for Claude Code hooks.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Esk3nder",
  "bin": {
    "claude-hook": "./bin/claude-hook",
    "claude-hooks-install": "./bin/claude-hooks-install"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dispatch": "bun run src/dispatcher.ts",
